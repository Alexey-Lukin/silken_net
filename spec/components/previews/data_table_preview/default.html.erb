    <td class="p-4 text-gaia-text-muted">15 min ago</td>
  </tr>
  <tr class="text-compact">
    <td class="p-4 text-gaia-text-muted">#003</td>
    <td class="p-4 text-gaia-text">Pine Gamma</td>
    <td class="p-4"><%= render Views::Shared::UI::StatusBadge.new(status: "failed") %></td>
