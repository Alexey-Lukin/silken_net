<div style="background: #000; padding: 2rem; font-family: monospace;">
  <h3 style="color: #10b981; margin-bottom: 1rem; font-size: 11px; text-transform: uppercase; letter-spacing: 0.2em;">Alert Badge — Severity × Status Matrix</h3>
  <table style="border-collapse: collapse;">
    <% %w[low medium critical].each do |severity| %>
      <% %w[active resolved ignored].each do |status| %>
        <tr>
          <td style="padding: 0.25rem 1rem; color: #065f46; font-size: 10px;"><%= severity %> / <%= status %></td>
          <td style="padding: 0.25rem;">
            <%= render Alerts::Badge.new(alert: OpenStruct.new(id: 1, severity: severity, status: status)) %>
          </td>
        </tr>
      <% end %>
    <% end %>
  </table>
</div>
