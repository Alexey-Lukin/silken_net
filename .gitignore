# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore all environment files.
/.env*

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore key files for decrypting credentials and more.
/config/*.key

/app/assets/builds/*
!/app/assets/builds/.keep

.DS_Store
vendor/bundle

# RSpec example status persistence
/spec/examples.txt

# SimpleCov coverage reports
/coverage/

# Terraform (GCP)
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.*
terraform/*.tfvars
!terraform/*.tfvars.example
terraform/.terraform.lock.hcl
terraform/tfplan

# Terraform (Akash)
terraform/akash/.terraform/
terraform/akash/*.tfstate
terraform/akash/*.tfstate.*
terraform/akash/*.tfvars
!terraform/akash/*.tfvars.example
terraform/akash/.terraform.lock.hcl
terraform/akash/tfplan
terraform/akash/generated-deploy.yaml
terraform/akash/akash-dseq.txt

# Firmware test binaries (host-based, compiled with gcc)
firmware/test/test_queen
firmware/test/test_soldier

# Subgraph build artifacts (The Graph)
subgraph/build/
subgraph/generated/
subgraph/node_modules/
