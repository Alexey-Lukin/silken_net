# Secrets defined here are available for reference under registry/password, env/secret, builder/secrets,
# and accessories/*/env/secret in config/deploy.yml. All secrets should be pulled from either
# password manager, ENV, or a file. DO NOT ENTER RAW CREDENTIALS HERE! This file needs to be safe for git.

# Rails master key for credentials decryption
RAILS_MASTER_KEY=$(cat config/master.key)

# Google Artifact Registry authentication (base64-encoded service account JSON key)
# Set GCP_SA_KEY environment variable or fetch from a secrets manager:
# GCP_ARTIFACT_REGISTRY_KEY=$GCP_SA_KEY
GCP_ARTIFACT_REGISTRY_KEY=$GCP_ARTIFACT_REGISTRY_KEY

# Database connection URL (Cloud SQL PostgreSQL via private IP)
# Set via environment variable or fetch from Terraform output:
# DATABASE_URL=postgres://silken_net:<password>@<cloud-sql-private-ip>:5432/silken_net_production
DATABASE_URL=$DATABASE_URL

# Redis connection URL (Memorystore for Sidekiq)
# Set via environment variable or fetch from Terraform output:
# REDIS_URL=redis://<memorystore-host>:6379/0
REDIS_URL=$REDIS_URL
